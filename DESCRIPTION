Package: saintexpress
Title: Pure R Implementation of SAINTexpress
Version: 0.0.1
Authors@R: c(
    person("Witold", "Wolski", , "wew@fgcz.ethz.ch",
        role = "aut",
        comment = c(ORCID = "0000-0002-6468-120X")),
    person("Christian", "Panse", , "cp@fgcz.ethz.ch",
        role = "cre",
